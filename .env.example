# ─── MySQL (Hostinger Remote) ───────────────────────
# IMPORTANT: Use your Hostinger server IP, NOT localhost
# Find it in: Hostinger → Databases → Remote MySQL
DB_HOST=YOUR_HOSTINGER_SERVER_IP
DB_PORT=3306
DB_NAME=u321644199_cms
DB_USER=u321644199_admincms
DB_PASSWORD=your_password_here

# ─── Auth ────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=generate_a_64_char_random_string
NEXTAUTH_URL=https://your-vercel-domain.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Site ────────────────────────────────────────────
SITE_URL=https://your-vercel-domain.vercel.app
SITE_NAME=My CMS

# ─── Email ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_FORM_TO=

# ─── GitHub ──────────────────────────────────────────
GITHUB_AUTO_COMMIT=false
GITHUB_REMOTE=origin
GITHUB_BRANCH=main

# ─── Other ───────────────────────────────────────────
NEWSLETTER_PROVIDER=database
ANALYTICS_SCRIPT=
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
