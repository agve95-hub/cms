# Database
DATABASE_PATH=./data/cms.db

# Auth
NEXTAUTH_SECRET=generate-with-node-e-console-log-require-crypto-randomBytes-32-toString-hex
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Security
ADMIN_ALLOWED_IPS=
RATE_LIMIT_ENABLED=true

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
CONTACT_FORM_TO=admin@example.com

# GitHub (push)
GITHUB_AUTO_COMMIT=false
GITHUB_REMOTE=origin
GITHUB_BRANCH=main
GITHUB_COMMIT_PREFIX=content:

# GitHub (pull)
GITHUB_WEBHOOK_SECRET=
GITHUB_PULL_ENABLED=false
GITHUB_PULL_AUTO=false
GITHUB_PULL_RESTART_ON_CODE=true

# Newsletter
NEWSLETTER_PROVIDER=database

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=3
BACKUP_PATH=./backups
BACKUP_REMOTE_ENABLED=false

# Analytics
ANALYTICS_SCRIPT=

# Logging
LOG_LEVEL=info

# Site
SITE_URL=http://localhost:3000
SITE_NAME=My CMS
